<root BTCPP_format="4">
    <BehaviorTree ID="SimpleSubscriberSample">
        <Repeat num_cycles="-1">
            <Sequence>
                <SimpleSubscriber/>
                <!-- Prevents from getting stuck without being able to interrupt with C^ -->
                <Sleep msec="10"/>
            </Sequence>
        </Repeat>
    </BehaviorTree>
</root>